{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://altrasia.local/schemas/map-layout-v1.json",
  "title": "MapLayoutV1",
  "type": "object",
  "required": ["schemaVersion"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "scope": { "enum": ["mini", "site", "stack", "floor"] },
    "architectureStyle": { "type": "string" },
    "referenceDiagramId": {
      "enum": ["mini_envelope", "mini_shapes", "site_overlay", "level_stack"]
    },
    "structures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["structureId"],
        "properties": {
          "structureId": { "type": "string" },
          "displayName": { "type": "string" },
          "kind": { "type": "string" },
          "boundary": { "type": "object" }
        }
      }
    },
    "scenes": { "type": "array" },
    "nodes": { "type": "array" },
    "edges": { "type": "array" },
    "worldMap": { "type": "object" }
  }
}
